<% layout("layouts/boilerplate") %>

<%- include("../includes/flash.ejs") %>

<div class="auth-page">

  <div class="auth-box">

    <h2>
      Welcome Back
    </h2>

    <p class="auth-subtitle">
      Login to continue exploring Wanderlust
    </p>


    <!-- Login Form -->

    <form
      action="/login"
      method="POST"
      class="needs-validation"
      novalidate
    >

      <!-- Username -->

      <div class="mb-3">

        <input
          name="username"
          id="username"
          type="text"
          class="form-control auth-input"
          placeholder="Enter username"
          autocapitalize="none"
          autocomplete="username"
          required
        >

        <div class="invalid-feedback">
          Please enter username
        </div>

      </div>


      <!-- Password -->

      <div class="mb-4">

        <input
          name="password"
          id="password"
          type="password"
          class="form-control auth-input"
          placeholder="Enter password"
          autocomplete="current-password"
          required
        >

        <div class="invalid-feedback">
          Please enter password
        </div>

      </div>


      <!-- Login Button -->

      <button
        type="submit"
        class="auth-main-btn"
      >

        <i class="fa-solid fa-right-to-bracket auth-btn-icon"></i>

        <span>
          Log In
        </span>

      </button>

    </form>


    <!-- Divider -->

    <div class="auth-divider">

      <span>
        OR
      </span>

    </div>


    <!-- Google Login -->

    <a
      href="/auth/google"
      class="google-btn"
    >

      <i class="fa-brands fa-google auth-btn-icon"></i>

      <span>
        Continue with Google
      </span>

    </a>


    <!-- Bottom Link -->

    <p class="auth-bottom-text">

      Don’t have an account?

      <a href="/signup">
        Sign Up
      </a>

    </p>

  </div>

</div>