<% layout("layouts/boilerplate") %>

<% if(loginError) { %>
  <div class="flash-wrapper">
    <div
      class="alert alert-danger alert-dismissible fade show custom-flash error-flash"
      role="alert"
    >
      <div class="flash-content">
        <div class="flash-icon">
          <i class="fa-solid fa-circle-exclamation"></i>
        </div>
        <div class="flash-message">
          <%= loginError %>
        </div>
      </div>
      <button
        type="button"
        class="btn-close"
        data-bs-dismiss="alert"
        aria-label="Close"
      ></button>
    </div>
  </div>
<% } %>

<div class="login-flash-wrapper">
  <%- include("../includes/flash.ejs") %>
</div>

<div class="auth-page">
  <div class="auth-box">

    <h2>Welcome Back</h2>
    <p class="auth-subtitle">Login to continue exploring Wanderlust</p>

    <form action="/login" method="POST" class="needs-validation" novalidate>

      <div class="mb-3">
        <input
          name="username"
          id="username"
          type="text"
          class="form-control auth-input"
          placeholder="Enter username"
          autocapitalize="none"
          autocomplete="username"
          required
        >
        <div class="invalid-feedback">Please enter username</div>
      </div>

      <div class="mb-4">
        <input
          name="password"
          id="password"
          type="password"
          class="form-control auth-input"
          placeholder="Enter password"
          autocomplete="current-password"
          required
        >
        <div class="invalid-feedback">Please enter password</div>
      </div>

      <button type="submit" class="auth-main-btn">
        <span class="btn-content">
          <i class="fa-solid fa-right-to-bracket auth-btn-icon"></i>
          <span>Log In</span>
        </span>
      </button>

    </form>

    <div class="auth-divider">
      <span>OR</span>
    </div>

    <a href="/auth/google" class="google-btn">
      <img
        src="https://upload.wikimedia.org/wikipedia/commons/c/c1/Google_%22G%22_logo.svg"
        alt="Google Logo"
        class="google-logo"
      >
      <span>Continue with Google</span>
    </a>

    <p class="auth-bottom-text">
      Don't have an account? <a href="/signup">Sign Up</a>
    </p>

  </div>
</div>