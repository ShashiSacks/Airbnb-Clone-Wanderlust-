<nav class="navbar sticky-top">
  <div class="container-fluid">

    <a class="navbar-brand" href="/listings">
      <div class="nav-logo-icon">
        <i class="fa-regular fa-compass"></i>
      </div>
      <span class="brand-text">Wanderlust</span>
    </a>

    <div class="nav-search-wrapper">

      <form action="/listings/search" method="GET" class="search-form">
        <div class="search-bar">
          <i class="fa-solid fa-magnifying-glass"></i>

          <input
            type="text"
            name="query"
            placeholder="Search destinations"
            class="search-input"
            value="<%= searchQuery || '' %>"
          >

          <button class="search-btn" type="submit">
            Search
          </button>
        </div>
      </form>

      <div class="nav-search-pill">

        <a
          class="pill-link <%= requestPath === '/listings' ? 'active-nav-link' : '' %>"
          href="/listings"
        >
          <i class="fa-solid fa-compass nav-icon"></i>
          <span>Discover</span>
        </a>

        <span class="pill-divider"></span>

        <a
          class="pill-link <%= requestPath === '/listings/new' ? 'active-nav-link' : '' %>"
          href="/listings/new"
        >
          <i class="fa-solid fa-circle-plus nav-icon"></i>
          <span>Add Listing</span>
        </a>

        <% if(currUser) { %>

          <span class="pill-divider"></span>

          <a
            class="pill-link <%= requestPath === '/listings/my-listings' ? 'active-nav-link' : '' %>"
            href="/listings/my-listings"
          >
            <i class="fa-solid fa-house nav-icon"></i>
            <span>Your Listings</span>
          </a>

          <span class="pill-divider"></span>

          <a
            class="pill-link <%= requestPath === '/wishlists' ? 'active-nav-link' : '' %>"
            href="/wishlists"
          >
            <i class="fa-regular fa-heart nav-icon"></i>
            <span>Wishlists</span>
          </a>

        <% } %>

      </div>

    </div>

    <div class="auth-links">

      <% if(!currUser) { %>

        <!-- LOGIN -->

        <a class="auth-link" href="/login">

          <span class="btn-content">

            <i class="fa-solid fa-right-to-bracket nav-icon"></i>

            <span>Log In</span>

          </span>

        </a>

        <!-- SIGNUP -->

        <a class="auth-link signup-pill" href="/signup">

          <span class="btn-content">

            <i class="fa-solid fa-user-plus nav-icon"></i>

            <span>Sign Up</span>

          </span>

        </a>

      <% } else { %>

        <!-- LOGOUT -->

        <a class="auth-link logout-pill" href="/logout">

          <span class="btn-content">

            <i class="fa-solid fa-right-from-bracket nav-icon"></i>

            <span>Log Out</span>

          </span>

        </a>

      <% } %>

    </div>

  </div>
</nav>