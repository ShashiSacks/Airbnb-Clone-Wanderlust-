<% if (success && success.length) { %>

  <div class="flash-wrapper">

    <div
      class="alert alert-success alert-dismissible fade show custom-flash success-flash"
      role="alert"
    >

      <div class="flash-content">

        <div class="flash-icon">
          <i class="fa-solid fa-circle-check"></i>
        </div>

        <div class="flash-message">
          <%= success %>
        </div>

      </div>

      <button
        type="button"
        class="btn-close"
        data-bs-dismiss="alert"
        aria-label="Close"
      >
      </button>

    </div>

  </div>

<% } %>


<% if (error && error.length) { %>

  <div class="flash-wrapper">

    <div
      class="alert alert-danger alert-dismissible fade show custom-flash error-flash"
      role="alert"
    >

      <div class="flash-content">

        <div class="flash-icon">
          <i class="fa-solid fa-circle-exclamation"></i>
        </div>

        <div class="flash-message">
          <%= error %>
        </div>

      </div>

      <button
        type="button"
        class="btn-close"
        data-bs-dismiss="alert"
        aria-label="Close"
      >
      </button>

    </div>

  </div>

<% } %>