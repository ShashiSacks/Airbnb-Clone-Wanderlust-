<% layout("layouts/boilerplate") %>

<div class="show-wrapper">

  <div class="show-card">

    <!-- Listing Title -->

    <h1 class="listing-title">
      <%= listing.title %>
    </h1>


    <!-- Listing Gallery -->

    <div class="listing-gallery">

      <!-- Main Image -->

      <div class="main-image">

        <img
          src="<%= listing.images && listing.images.length > 0 ? listing.images[0].url : '/default.jpg' %>"
          alt="listing_image"
          class="gallery-img"
          onclick="openImage(this.src)"
        >

      </div>


      <!-- Side Images -->

      <div class="side-images">

        <% if(listing.images && listing.images.length > 1) { %>

          <img
            src="<%= listing.images[1].url %>"
            alt="listing_image"
            class="gallery-img"
            onclick="openImage(this.src)"
          >

        <% } %>

        <% if(listing.images && listing.images.length > 2) { %>

          <img
            src="<%= listing.images[2].url %>"
            alt="listing_image"
            class="gallery-img"
            onclick="openImage(this.src)"
          >

        <% } %>

      </div>

    </div>


    <!-- Listing Information -->

    <div class="listing-info">

      <p class="owner-text">

        Owned by

        <i>
          <%= listing.owner ? listing.owner.username : "Anonymous" %>
        </i>

      </p>


      <p class="listing-meta">

        <b>Price:</b>

        ₹<%= listing.price
          ? listing.price.toLocaleString("en-IN")
          : "N/A" %> / night

      </p>


      <p class="listing-meta">

        <b>Location:</b>

        <%= listing.location %>

      </p>


      <p class="listing-meta">

        <b>Country:</b>

        <%= listing.country %>

      </p>


      <p class="listing-description">
        <%= listing.description %>
      </p>


      <!-- Map Section -->

      <div class="map-section">

        <h2 class="map-heading">
          Where you'll be
        </h2>

        <p class="map-location">

          <%= listing.location %>,
          <%= listing.country %>

        </p>

        <div id="map"></div>

      </div>

    </div>


    <!-- Show Actions -->

    <div class="show-actions">

      <!-- Book Now -->

<div class="book-now-wrapper">

  <% if(currUser) { %>

    <form
      method="POST"
      action="/create-checkout-session/<%= listing._id %>"
    >

      <button
        type="submit"
        class="btn btn-book-now btn-fixed"
      >
        Book Now
      </button>

    </form>

  <% } else { %>

    <a
      href="/login"
      class="btn btn-book-now btn-fixed"
    >
    
    Book Now
    </a>

  <% } %>

</div>
      <!-- Edit Delete Buttons -->

      <div class="edit-delete-wrapper">

        <a
          href="/listings/<%= listing._id %>/edit"
          class="btn btn-primary-action btn-fixed"
        >
          Edit
        </a>

        <form
          method="POST"
          action="/listings/<%= listing._id %>?_method=DELETE"
        >

          <button
            type="submit"
            class="btn btn-danger-action btn-fixed"
          >
            Delete
          </button>

        </form>

      </div>

    </div>

  </div>

</div>


<!-- Divider -->

<hr class="show-divider">


<!-- Review Section -->

<div class="review-container">

  <h2 class="text-center mb-4">
    Leave a Review
  </h2>


  <!-- Review Form -->

  <form
    method="POST"
    action="/listings/<%= listing._id %>/reviews"
    novalidate
    class="needs-validation"
  >

    <!-- Rating -->

    <div class="review-field text-center mb-4">

      <label class="d-block mb-3">
        Rating
      </label>

      <fieldset class="starability-slot">

        <input
          type="radio"
          id="no-rate"
          class="input-no-rate"
          name="review[rating]"
          value="0"
          checked
          aria-label="No rating."
        />

        <input
          type="radio"
          id="first-rate1"
          name="review[rating]"
          value="1"
        >

        <label
          for="first-rate1"
          title="Terrible"
        >
          1 star
        </label>

        <input
          type="radio"
          id="first-rate2"
          name="review[rating]"
          value="2"
        >

        <label
          for="first-rate2"
          title="Not good"
        >
          2 stars
        </label>

        <input
          type="radio"
          id="first-rate3"
          name="review[rating]"
          value="3"
        >

        <label
          for="first-rate3"
          title="Average"
        >
          3 stars
        </label>

        <input
          type="radio"
          id="first-rate4"
          name="review[rating]"
          value="4"
        >

        <label
          for="first-rate4"
          title="Very good"
        >
          4 stars
        </label>

        <input
          type="radio"
          id="first-rate5"
          name="review[rating]"
          value="5"
        >

        <label
          for="first-rate5"
          title="Amazing"
        >
          5 stars
        </label>

      </fieldset>

    </div>


    <!-- Comment -->

    <div class="review-field text-center mb-4">

      <label
        for="comment"
        class="d-block mb-2"
      >
        Comments
      </label>

      <textarea
        name="review[comment]"
        id="comment"
        rows="4"
        placeholder="Write your review here..."
        class="center-input form-control"
        required
      ></textarea>

      <div class="invalid-feedback">
        Please add some comments for review
      </div>

    </div>


    <!-- Submit Button -->

    <div class="text-center mt-3">

      <button
        type="submit"
        class="btn btn-submit-action btn-fixed"
      >
        Post Review
      </button>

    </div>

  </form>


  <!-- Divider -->

  <hr class="my-5">


  <!-- Reviews Heading -->

  <h2 class="text-center mb-2">
    All Reviews
  </h2>


  <% let totalReviews = listing.reviews.length; %>

  <div class="text-center mb-5">

    <p class="text-muted">
      <%= totalReviews %> Reviews
    </p>

  </div>


  <!-- Reviews -->

  <div class="row justify-content-center">

    <% for (let review of listing.reviews) { %>

      <div class="col-md-5 mb-4">

        <div class="card review-card shadow-sm">

          <div class="card-body text-center">

            <h5 class="card-title">

              @<%= review.author
                ? review.author.username
                : "Anonymous" %>

            </h5>

            <p
              class="starability-result"
              data-rating="<%= review.rating %>"
            >
              Rated:
              <%= review.rating %> stars
            </p>

            <p class="card-text">
              <%= review.comment %>
            </p>


            <!-- Review Action Buttons -->

            <div class="edit-delete-wrapper">

              <a
                href="/listings/<%= listing._id %>/reviews/<%= review._id %>/edit"
                class="btn btn-primary-action"
              >
                Edit
              </a>

              <form
                method="POST"
                action="/listings/<%= listing._id %>/reviews/<%= review._id %>?_method=DELETE"
              >

                <button class="btn btn-danger-action">

                  Delete

                </button>

              </form>

            </div>

          </div>

        </div>

      </div>

    <% } %>

  </div>

</div>


<!-- Listing Data For Leaflet -->

<script>

  const listing = {

    title: "<%= listing.title %>",

    location: "<%= listing.location %>",

    country: "<%= listing.country %>",

    geometry: {

      coordinates: [<%= listing.geometry.coordinates[0] %>, <%= listing.geometry.coordinates[1] %>]

    }

  };

</script>


<!-- Image Modal -->

<div
  id="imageModal"
  class="image-modal"
>

  <span
    class="close-modal"
    onclick="closeImage()"
  >
    &times;
  </span>

  <img
    class="modal-content-img"
    id="popupImage"
  >

</div>